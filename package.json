{
  "name": "translator-prototype",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "desktop": "concurrently -k -s first \"npm:dev\" \"npm:desktop:open\"",
    "desktop:open": "wait-on http://127.0.0.1:5173 && electron . --dev-server=http://127.0.0.1:5173",
    "desktop:preview": "npm run build && electron .",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@fluentui/react-icons": "^2.0.331",
    "@vitejs/plugin-react": "5.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tesseract.js": "^7.0.0",
    "vite": "^6.4.3"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "electron": "^42.5.0",
    "wait-on": "^9.0.10"
  }
}
